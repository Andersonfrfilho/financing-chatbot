{
  "name": "financiamento-imobiliario-bot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare": "husky",
    "api:dev": "bun run --cwd apps/api dev",
    "api:start": "bun run --cwd apps/api start",
    "web:dev": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "~5.7.3"
  }
}
