# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_USER=financiamento
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=financiamento_bot

# ──────────────────────────────────────────────
# API
# ──────────────────────────────────────────────
PORT=3333
NODE_ENV=development
DATABASE_URL=postgres://financiamento:changeme_postgres@postgres:5432/financiamento_bot

# Gere com: openssl rand -hex 32
JWT_SECRET=changeme_gere_com_openssl_rand_hex_32
JWT_REFRESH_SECRET=changeme_gere_com_openssl_rand_hex_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Gere com: openssl rand -hex 32 (criptografia AES-256 de dados LGPD)
ENCRYPTION_KEY=changeme_gere_com_openssl_rand_hex_32

# Token para chamadas internas n8n → API
API_INTERNAL_TOKEN=changeme_gere_com_openssl_rand_hex_32

ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info

# ──────────────────────────────────────────────
# WhatsApp (Meta Cloud API)
# Obter em: developers.facebook.com/apps → WhatsApp → Primeiros passos
# ──────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=changeme_qualquer_string_sua_escolha
WHATSAPP_API_VERSION=v21.0

# ──────────────────────────────────────────────
# n8n
# ──────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme_n8n
N8N_HOST=localhost
# Em produção: URL pública do n8n (ex: https://n8n.seudominio.com)
N8N_WEBHOOK_URL=http://localhost:5678
