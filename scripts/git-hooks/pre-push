#!/bin/sh
# Verificação antes do push. Bloqueia o push se algo falhar.
# 1) Se apps/web mudou → build + smoke-test do frontend (igual ao Railway).
# 2) Sempre → testes da máquina de estados do n8n.

REMOTE_HEAD=$(git rev-parse @{u} 2>/dev/null || echo "")
if [ -n "$REMOTE_HEAD" ]; then
  RANGE="$REMOTE_HEAD..HEAD"
else
  RANGE="HEAD"
fi

# ── 1. Frontend (só se mudou apps/web) ─────────────────────────────
if git diff --name-only $RANGE 2>/dev/null | grep -q '^apps/web/'; then
  echo "▶ apps/web mudou — verificando build + healthcheck do frontend..."
  make verify-web
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Frontend falhou (build ou healthcheck). Push bloqueado."
    exit 1
  fi
else
  echo "▶ apps/web não mudou — pulando verify-web."
fi

# ── 2. Fluxo do n8n ────────────────────────────────────────────────
echo "▶ Executando make test-n8n..."
make test-n8n
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Testes do n8n falharam. Push bloqueado."
  echo "   Corrija os erros acima antes de subir."
  exit 1
fi
echo "✅ Verificações ok — prosseguindo com o push."
